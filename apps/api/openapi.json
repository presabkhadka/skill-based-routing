  "info": {
    "title": "Skill-Based Routing API",
    "description": "Matches service requests to qualified, available technicians by skill, level, availability, and workload.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "CreateSkillDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60
          }
        },
        "required": [
          "name"
        ]
      },
      "CreateTechnicianDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "available": {
            "type": "boolean",
            "default": true
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "skill": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 60
                },
                "level": {
                  "type": "integer",
                  "minimum": 1,
                  "exclusiveMinimum": false,
                  "maximum": 5,
                  "exclusiveMaximum": false
                }
              },
              "required": [
                "skill",
                "level"
              ]
            },
            "default": []
          },
          "workingHours": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "day": {
                  "type": "integer",
                  "minimum": 0,
                  "exclusiveMinimum": false,
                  "maximum": 6,
                  "exclusiveMaximum": false
                },
                "start": {
                  "type": "string",
                  "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
                },
                "end": {
                  "type": "string",
                  "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
                }
              },
              "required": [
                "day",
                "start",
                "end"
              ]
            },
            "default": []
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateTechnicianDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "available": {
            "type": "boolean"
          },
          "workingHours": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "day": {
                  "type": "integer",
                  "minimum": 0,
                  "exclusiveMinimum": false,
                  "maximum": 6,
                  "exclusiveMaximum": false
                },
                "start": {
                  "type": "string",
                  "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
                },
                "end": {
                  "type": "string",
                  "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
                }
              },
              "required": [
                "day",
                "start",
                "end"
              ]
            }
          }
        }
      },
      "SetSkillsDto": {
        "type": "object",
        "properties": {
          "skills": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "skill": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 60
                },
                "level": {
                  "type": "integer",
                  "minimum": 1,
                  "exclusiveMinimum": false,
                  "maximum": 5,
                  "exclusiveMaximum": false
                }
              },
              "required": [
                "skill",
                "level"
              ]
            }
          }
        },
        "required": [
          "skills"
        ]
      },
      "SetAvailabilityDto": {
        "type": "object",
        "properties": {
          "available": {
            "type": "boolean"
          }
        },
        "required": [
          "available"
        ]
      },
      "CreateServiceRequestDto": {
        "type": "object",
        "properties": {
          "customer": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "priority": {
            "type": "string",
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW"
            ],
            "default": "MEDIUM"
          },
          "requiredSkills": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 1,
              "exclusiveMinimum": false,
              "maximum": 5,
              "exclusiveMaximum": false
            }
          },
          "scheduledDay": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": false,
            "maximum": 6,
            "exclusiveMaximum": false
          },
          "scheduledTime": {
            "type": "string",
            "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
          }
        },
        "required": [
          "customer",
          "requiredSkills"
        ]
      }
    }
  }
}